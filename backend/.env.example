# OAuth Social Login (Google)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/auth/social/callback/google

# OAuth Social Login (Kakao)
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_KAKAO_REDIRECT_URI=http://localhost:8080/auth/social/callback/kakao

# Frontend/Backend base URLs
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_BACKEND_BASE_URL=http://localhost:8080

# Backend secrets (required)
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
JWT_SECRET=

# Internal Django integration (required for ledger/brix internal calls)
DJANGO_BRIX_BASE_URL=http://127.0.0.1:8000
DJANGO_INTERNAL_API_KEY=
# Optional override per feature. Leave blank to reuse DJANGO_BRIX_* values.
DJANGO_LEDGER_BASE_URL=
DJANGO_LEDGER_API_KEY=

# Optional
OAUTH_STATE_EXPIRATION_SECONDS=300
